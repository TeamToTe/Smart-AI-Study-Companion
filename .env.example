# Example Environment Variables Configuration
# Copy this file to '.env' and fill in your actual keys.
# Do NOT commit '.env' to git!

# Gemini API Keys (comma-separated list for rotation)
GEMINI_API_KEYS="AIzaSyYourKey1,AIzaSyYourKey2"

# Groq API Keys (comma-separated list for rotation)
GROQ_API_KEYS="gsk_YourKey1,gsk_YourKey2"

# Local Redis URL (used by Celery and Rate Limiter)
REDIS_URL="redis://localhost:6379/0"

# Supabase Configurations
SUPABASE_URL="https://your-project-id.supabase.co"
ANON_KEY="your-anon-public-key"
SUPABASE_JWT="your-jwt-signing-secret-or-public-key-configuration"

